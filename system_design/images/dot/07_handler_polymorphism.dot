
digraph polymorphism {
    rankdir=TB;
    node [shape=box, style=rounded];
    
    Interface [label="VPN Handler\nInterface Contract"];
    
    WireGuard [label="WireGuardHandler\n(Cross-platform)"];
    RealWin [label="RealWindowsWireGuard\n(Windows Native)"];
